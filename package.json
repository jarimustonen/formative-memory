{
  "name": "formative-memory",
  "version": "0.5.0",
  "description": "Memory plugin for OpenClaw. Agent's memories strengthen through use, fade when unused, and consolidate overnight.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jarimustonen/formative-memory.git"
  },
  "keywords": [
    "openclaw",
    "memory",
    "associative-memory",
    "plugin"
  ],
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "memory": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsdown",
    "check": "pnpm format:check && pnpm tsgo && pnpm lint",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "format:fix": "oxfmt --write",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix && pnpm format",
    "tsgo": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "version": "node -e \"const m=require('./openclaw.plugin.json');m.version=require('./package.json').version;require('fs').writeFileSync('openclaw.plugin.json',JSON.stringify(m,null,2)+'\\n')\" && git add openclaw.plugin.json"
  },
  "dependencies": {
    "@sinclair/typebox": "0.34.48",
    "markdown-it": "^14.1.1"
  },
  "devDependencies": {
    "@rolldown/binding-darwin-arm64": "1.0.0-rc.12",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.0.18",
    "openclaw": "^2026.4.15",
    "oxfmt": "0.35.0",
    "oxlint": "^1.50.0",
    "tsdown": "^0.20.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.15"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.23.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "files": [
    "dist",
    "openclaw.plugin.json"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  }
}
