#!/usr/bin/env bash
# Wrapper for inspecting Sylvia's associative memory on haapa.
#
# Usage:
#   sylvia-memory stats
#   sylvia-memory list [--type fact] [--min-strength 0.5] [--limit 10]
#   sylvia-memory inspect <id>
#   sylvia-memory search <query>
#   sylvia-memory history <id>
#   sylvia-memory graph [--dot]
#   sylvia-memory export
#   sylvia-memory import <file>
#   sylvia-memory sql <query>      — raw sqlite3 query

set -euo pipefail

REMOTE="haapa"
# Host path (for sqlite3 direct access)
DB_PATH="/srv/storage/openclaw/jari/memory/associative/associations.db"
# Container paths
CONTAINER="openclaw-jari"
MEMORY_DIR_CONTAINER="/home/node/.openclaw/memory/associative"
CLI="/home/node/.openclaw/extensions/memory-associative/dist/cli.js"

cmd="${1:-help}"
shift 2>/dev/null || true

case "$cmd" in
  sql)
    ssh "$REMOTE" "sqlite3 '$DB_PATH' \"$*\""
    ;;
  help|-h|--help)
    echo "Usage: sylvia-memory <command> [options]"
    echo ""
    echo "Commands:"
    echo "  stats                        Overview of memory database"
    echo "  list [options]               List memories (--type, --state, --min-strength, --limit)"
    echo "  inspect <id>                 Detailed view of a single memory"
    echo "  search <query>               Search memories by content"
    echo "  history <id>                 Memory lifecycle timeline"
    echo "  graph [--dot]                Association network"
    echo "  export                       Full DB export as JSON"
    echo "  import <file>                Import JSON into DB"
    echo "  sql <query>                  Raw sqlite3 query"
    ;;
  *)
    # Run CLI inside the container (Node 24 with node:sqlite support)
    ssh "$REMOTE" "podman exec $CONTAINER node --no-warnings $CLI $cmd $MEMORY_DIR_CONTAINER --text $*"
    ;;
esac
